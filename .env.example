# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key from https://aistudio.google.com/apikey (no credit card required).
GEMINI_API_KEY=

# ── Models ───────────────────────────────────────────────────────────────────
# gemini-2.0-flash has no free-tier quota on newer API keys/projects (retired).
# gemini-2.5-flash works but is capped at a very low free-tier RPM (as low as 5
# on some projects) — too tight for this agent's multi-step call pattern.
# gemini-2.5-flash-lite has a much higher free-tier RPM and handled rapid
# back-to-back calls fine in testing, while still producing solid JSON/prose.
# See https://ai.google.dev/gemini-api/docs/models for current models and limits.
PLANNER_MODEL=gemini-2.5-flash-lite
EXECUTOR_MODEL=gemini-2.5-flash-lite
REFLECTION_MODEL=gemini-2.5-flash-lite

# ── LLM Settings ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=800
EXECUTOR_MAX_TOKENS=500
# Per-attempt request timeout in seconds. Keep this well under the platform's
# function duration limit (e.g. Vercel Hobby caps at 300s) since llm_service
# retries up to 3 times.
LLM_REQUEST_TIMEOUT=25

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: http://localhost:3000,https://your-frontend.vercel.app
ALLOWED_ORIGINS=
